# ============ StudyPilot — Variables de Entorno ============
# Copia este archivo como .Renviron (o app_env) y llena tus valores.
# NUNCA subas .Renviron ni app_env a GitHub.

# MongoDB Atlas (obligatorio)
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/studypilot?retryWrites=true&w=majority

# Google Gemini API Key (obligatorio para funciones de IA)
# Obtén tu key en: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSy_tu_key_aqui

# Usuarios admin (formato: user:pass:Nombre)
STUDYPILOT_ADMIN_USERS=tu.usuario:tu_password:Tu Nombre
