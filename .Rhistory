# Clean all academic data from MongoDB — keep only users
library(mongolite)
MONGO_URI <- "mongodb+srv://appuser:MiClave2026utec@plan-estudios.9ugygin.mongodb.net/plan_estudios?retryWrites=true&w=majority"
for (col_name in c("courses", "activities", "grades", "study_notes", "syllabi", "exam_checks", "pomo_sessions")) {
m <- mongo(collection = col_name, url = MONGO_URI)
n <- m$count()
if (n > 0) {
m$drop()
cat(sprintf("  🗑 %-18s: %d docs eliminados\n", col_name, n))
} else {
cat(sprintf("  ✅ %-18s: ya vacío\n", col_name))
}
m$disconnect()
}
