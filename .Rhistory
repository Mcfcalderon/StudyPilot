# Insert all courses and activities into MongoDB
courses_col <- mongo(collection = "courses", url = MONGO_URI)
activities_col <- mongo(collection = "activities", url = MONGO_URI)
notes_col <- mongo(collection = "study_notes", url = MONGO_URI)
act_id <- 1L
for (c in courses_data) {
# Insert course
course_doc <- data.frame(
id = c$id, name = c$name, short = c$short, credits = c$credits,
professor = c$professor, formula = c$formula, eval_day = c$eval_day, color = c$color,
stringsAsFactors = FALSE
)
courses_col$insert(course_doc)
# Insert activities (evaluations)
for (ev in c$evals) {
act_doc <- data.frame(
act_id = act_id,
course_id = c$id,
type = ev$type,
name = ev$label,
code = ev$code,
date = as.character(week_to_date(ev$week, c$eval_day)),
week = ev$week,
weight = ev$w,
done = 0L,
done_date = NA_character_,
notes = paste0("Semana ", ev$week),
stringsAsFactors = FALSE
)
activities_col$insert(act_doc)
act_id <- act_id + 1L
}
# Save topics as study note
if (length(c$topics) > 0) {
topics_text <- paste0("Temas del curso ", c$name, ":\n",
paste(seq_along(c$topics), c$topics, sep = ". ", collapse = "\n"))
notes_col$insert(data.frame(
note_id = paste0("topics_", c$id),
course_id = c$id,
text_content = topics_text,
source = "Temas del sílabo",
created_at = as.character(Sys.time()),
stringsAsFactors = FALSE
))
}
cat(sprintf("  ✅ %s (%s) — %d evaluaciones, %d temas\n", c$short, c$id, length(c$evals), length(c$topics)))
}
courses_col$disconnect()
activities_col$disconnect()
notes_col$disconnect()
cat("\n✅ Todos los cursos insertados en MongoDB\n")
