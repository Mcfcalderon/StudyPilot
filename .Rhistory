# Find key sections
for (pat in c("IN4009|Gesti.n de Proy", "Cr.ditos|CREDITOS|credits", "Profesor|Docente|DOCENTE",
"CONTENIDO|UNIDAD|TEMA|PROGRAMACI", "SISTEMA DE EVALUACI", "BIBLIOGRAF")) {
idx <- grep(pat, lines, ignore.case = TRUE)
if (length(idx) > 0) {
cat(sprintf("\n--- Pattern '%s' at lines: %s ---\n", pat, paste(idx, collapse=",")))
for (i in idx[1:min(2, length(idx))]) {
start <- max(1, i-1)
end <- min(length(lines), i+2)
for (j in start:end) cat(sprintf("  L%d: %s\n", j, lines[j]))
}
}
}
