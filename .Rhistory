# Now extract all 6 syllabi with the corrected API call
extract_syllabus_smart <- function(text, code) {
lines <- strsplit(text, "\n")[[1]]
eval_idx <- grep("SISTEMA DE EVALUACI", lines, ignore.case = TRUE)
first_part <- substr(text, 1, 2500)
eval_text <- if (length(eval_idx) > 0) {
paste(lines[max(1, eval_idx[1]-3):min(length(lines), eval_idx[1]+60)], collapse = "\n")
} else ""
combined <- paste0(first_part, "\n\n--- SECCIÓN DE EVALUACIÓN ---\n\n", eval_text)
prompt <- paste0(
"Extrae la información de este sílabo universitario en formato JSON.\n",
"Responde SOLO el JSON, sin markdown ni ```json.\n\n",
'{"nombre_curso":"...","codigo":"', code, '","creditos":4,"profesor":"...",',
'"formula":"descripción de fórmula",',
'"evaluaciones":[{"nombre":"Examen Parcial","codigo":"EP1","peso":25,"semana":8,"tipo":"examen"}],',
'"temas":["Tema 1","Tema 2"]}\n\n',
"tipo: examen, ec, proyecto. semana: 1-16. peso: sin %. INCLUYE TODAS las evaluaciones.\n\n",
"--- SÍLABO ---\n", combined
)
chat <- chat_google_gemini(api_key = "AQ.Ab8RN6Jc70BFjY-gxNQm9Sqf9F2kaMRs5K4yexk8vUDwxx1tng", model = "gemini-2.5-flash")
response <- chat$chat(prompt)
response <- gsub("```json\\s*", "", response)
response <- gsub("```\\s*", "", response)
jsonlite::fromJSON(trimws(response), simplifyVector = TRUE)
}
